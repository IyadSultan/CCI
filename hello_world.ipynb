# --- Optimus MRN decryption ---
# VISTA MRNs are encoded: vista_mrn = optimus.encode(raw_mrn)
# To recover raw MRN from a VISTA MRN: raw_mrn = optimus.decode(vista_mrn)
from optimus_ids import Optimus
oprime  = dbutils.secrets.get(scope="sql-credentials", key="OPTIMUS_PRIME")
orandom = dbutils.secrets.get(scope="sql-credentials", key="OPTIMUS_RANDOM")
optimus = Optimus(prime=int(oprime), random=int(orandom))

# UDF to decode VISTA MRN → raw MRN inside Spark DataFrame
def decode_vista_mrn(vista_mrn):
    """Recover raw MRN from Optimus-encoded VISTA MRN using decode()."""
    try:
        return int(optimus.decode(int(vista_mrn)))
    except Exception:
        return None

decode_mrn_udf = F.udf(decode_vista_mrn, LongType())

