# COMMAND ----------
# ── Cell 3: Helper — JDBC reader ───────────────────────────────────────────────
# Wraps spark.read.jdbc with a consistent interface and error logging.

def read_jdbc(query: str, label: str = "") -> "DataFrame":
    """Read a SQL query via JDBC and return a Spark DataFrame.
    Wraps the query in 'SELECT * FROM (...) AS tmp' automatically.
    """
    try:
        df = spark.read.jdbc(
            url=JDBC_URL,
            table=f"({query}) AS tmp",
            properties=JDBC_PROPS,
        )
        count = df.count()
        print(f"   ✅ {label or 'Query'}: {count:,} rows")
        return df
    except Exception as e:
        logger.error(f"JDBC read failed [{label}]: {e}")
        raise

print("✅ JDBC helper defined")

