# ── Cell 16: Validation checks ────────────────────────────────────────────────
# Run these before writing. Review counts and spot-check values.

print("=" * 60)
print("VALIDATION REPORT")
print("=" * 60)

# V1: Row counts by study period
print("\nV1 — Encounter counts by study period:")
df.groupBy("study_period").count().show()

# V2: Before-noon discharge rate
print("V2 — Before-noon discharge rate by period:")
df.groupBy("study_period").agg(
    F.count("*").alias("total"),
    F.sum("discharged_before_noon_flag").alias("before_noon"),
    F.round(F.sum("discharged_before_noon_flag") * 100.0 / F.count("*"), 1).alias("pct_before_noon")
).show()

# V3: Mean LOS
print("V3 — Mean LOS by period:")
df.groupBy("study_period").agg(
    F.round(F.avg("los_days"), 2).alias("mean_los_days"),
    F.round(F.avg("los_hours"), 1).alias("mean_los_hours"),
).show()

# V4: Readmission rates
print("V4 — Readmission rates by period:")
df.groupBy("study_period").agg(
    F.count("*").alias("total"),
    F.sum("readmitted_7d_flag").alias("readmitted_7d"),
    F.sum("readmitted_30d_flag").alias("readmitted_30d"),
    F.round(F.sum("readmitted_7d_flag") * 100.0 / F.count("*"), 1).alias("pct_7d"),
    F.round(F.sum("readmitted_30d_flag") * 100.0 / F.count("*"), 1).alias("pct_30d"),
).show()

# V5: Weekend vs weekday
print("V5 — Weekend vs weekday discharge:")
df.groupBy("study_period", "weekday_or_weekend").count().orderBy("study_period").show()

# V6: Null rates for key columns (data quality check)
print("V6 — Null rates for key columns:")
total = df.count()
key_cols = [
    "age_at_admission", "gender", "nationality",
    "discharge_summary_completed_at", "discharge_summary_lag_hours",
    "had_icu_stay", "social_work_involved_flag",
    "readmitted_30d_flag", "ed_revisit_72h_flag",
    "followup_booked_before_discharge_flag",
]
null_rates = [(c, df.filter(F.col(c).isNull()).count(), total) for c in key_cols]
null_df = spark.createDataFrame(
    [(c, n, round(n * 100.0 / total, 1)) for c, n, _ in null_rates],
    ["column", "null_count", "null_pct"]
)
null_df.show(truncate=False)

# V7: Discharge destination distribution
print("V7 — Discharge destination breakdown:")
df.groupBy("discharge_destination").count().orderBy(F.col("count").desc()).show(truncate=False)

