# COMMAND ----------
# ── Cell 5: Spine — silver_admissions ─────────────────────────────────────────
# One row per inpatient encounter in the study window.
# Applies ward filter and day-case exclusion from config.

day_case_filter = "AND admission_to_discharge_hours > 0" if EXCLUDE_DAY_CASES else ""

excluded_types_sql = ", ".join(EXCLUDED_DISCHARGE_TYPES)

ward_filter_sql = ""
if WARD_FILTER:
    quoted = ", ".join(f"'{w}'" for w in WARD_FILTER)
    ward_filter_sql = f"AND UPPER(WARD_LOCATION) IN ({quoted.upper()})"

test_limit_sql = f"TOP {TEST_LIMIT}" if TEST_MODE else ""

spine_query = f"""
    SELECT {test_limit_sql}
        sa.MRN,
        sa.ADMISSION_NUMBER,
        sa.DISCHARGE_NUMBER,
        sa.HOSPITALIZATION_DATE                         AS admission_datetime,
        sa.DISCHARGE_DATE                               AS discharge_datetime,
        sa.DAYS_OF_HOSPITALIZATION                      AS los_days,
        sa.admission_to_discharge_hours                 AS los_hours,
        sa.WARD_LOCATION                                AS admission_ward,
        sa.DIAGNOSIS_SHORT                              AS primary_diagnosis,
        sa.lookup_floor,
        sa.lookup_ward,

        -- [FIX 1] Admission subtype from vista_patient_movement ADMISSION row
        -- silver_admissions.ADMISSION_TYPE only stores 'ADMISSION'/'TRANSFER'
        -- The clinical subtype (ELECTIVE/URGENT/EMERGENCY) lives in TYPE_OF_MOVEMENT
        adm_mov.TYPE_OF_MOVEMENT                        AS admission_type,

        -- [FIX 1] Discharge subtype from vista_patient_movement DISCHARGE row
        -- silver_admissions.DISCHARGE_TYPE only stores 'DISCHARGE'/'TRANSFER'
        -- The clinical value (DISCHARGE HOME/REGULAR/DEATH/AMA) lives in TYPE_OF_MOVEMENT
        dis_mov.TYPE_OF_MOVEMENT                        AS discharge_destination,

        -- Study period label
        CASE
            WHEN sa.DISCHARGE_DATE >= '{PRE_START}'
             AND sa.DISCHARGE_DATE  < '{PRE_END}'  THEN 'pre_intervention'
            WHEN sa.DISCHARGE_DATE >= '{POST_START}'
             AND sa.DISCHARGE_DATE  < '{POST_END}' THEN 'post_intervention'
        END                                             AS study_period,

        -- Discharge date parts
        CAST(sa.DISCHARGE_DATE AS DATE)                 AS discharge_date,
        DATEPART(HOUR, sa.DISCHARGE_DATE)               AS discharge_hour,

        -- Before-noon flag
        CASE WHEN DATEPART(HOUR, sa.DISCHARGE_DATE) < 12
             THEN 1 ELSE 0
        END                                             AS discharged_before_noon_flag,

        -- Weekend flag
        CASE WHEN DATENAME(WEEKDAY, sa.DISCHARGE_DATE)
                  IN ('Saturday','Sunday')
             THEN 'weekend' ELSE 'weekday'
        END                                             AS weekday_or_weekend,

        -- Admission type grouped (from the correctly joined TYPE_OF_MOVEMENT)
        CASE
            WHEN UPPER(adm_mov.TYPE_OF_MOVEMENT) LIKE '%EMERGENCY%'
              OR UPPER(adm_mov.TYPE_OF_MOVEMENT) LIKE '%URGENT%'   THEN 'Emergency/Urgent'
            WHEN UPPER(adm_mov.TYPE_OF_MOVEMENT) LIKE '%ELECTIVE%' THEN 'Elective'
            WHEN UPPER(adm_mov.TYPE_OF_MOVEMENT) LIKE '%DAY CASE%' THEN 'Day Case'
            WHEN UPPER(adm_mov.TYPE_OF_MOVEMENT) LIKE '%DIRECT%'   THEN 'Direct'
            ELSE ISNULL(adm_mov.TYPE_OF_MOVEMENT, 'Unknown')
        END                                             AS admission_type_grouped,

        -- Inpatient death flag (from discharge movement TYPE_OF_MOVEMENT)
        CASE WHEN UPPER(dis_mov.TYPE_OF_MOVEMENT) LIKE '%DEATH%'
             THEN 1 ELSE 0
        END                                             AS inpatient_death_flag

    FROM dbo.silver_admissions sa

    -- [FIX B] Join admission movement row by ADMISSION_NUMBER = NUMBER
    -- No TRANSACTION filter — TRANSFER-originated encounters have ADMISSION_NUMBER
    -- pointing to a TRANSFER row, not an ADMISSION row. Filter was dropping 40% of rows.
    LEFT JOIN dbo.vista_patient_movement adm_mov
        ON adm_mov.NUMBER = sa.ADMISSION_NUMBER

    -- [FIX B] Join discharge movement row by DISCHARGE_NUMBER = NUMBER
    -- No TRANSACTION filter — same reason as above.
    LEFT JOIN dbo.vista_patient_movement dis_mov
        ON dis_mov.NUMBER = sa.DISCHARGE_NUMBER

    WHERE sa.DISCHARGE_DATE >= '{PRE_START}'
      AND sa.DISCHARGE_DATE  < '{POST_END}'
      -- Exclude cancelled stays using the discharge movement TYPE_OF_MOVEMENT
      AND UPPER(ISNULL(dis_mov.TYPE_OF_MOVEMENT,'')) NOT IN (
          'CANCELLED ADMISSION', 'CANCELLED PROCEDURE'
      )
      {day_case_filter}
      {ward_filter_sql}
"""

print("Loading spine...")
df_spine = read_jdbc(spine_query, label="spine (silver_admissions)")

# [FIX E] Deduplicate spine on DISCHARGE_NUMBER — silver_admissions can have
# multiple rows per DISCHARGE_NUMBER with different ADMISSION_NUMBERs.
# Keep earliest HOSPITALIZATION_DATE per DISCHARGE_NUMBER (the true admission row).
# Cannot do this in SQL Server JDBC subquery (ORDER BY without TOP is forbidden).
from pyspark.sql.window import Window
spine_window = Window.partitionBy("DISCHARGE_NUMBER").orderBy(F.col("admission_datetime").asc())
df_spine = df_spine.withColumn("_spine_rn", F.row_number().over(spine_window)) \
                   .filter(F.col("_spine_rn") == 1) \
                   .drop("_spine_rn")

spine_count = df_spine.count()
print(f"   ✅ After dedup: {spine_count:,} unique encounters")
display(df_spine.limit(5))

