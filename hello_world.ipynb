# COMMAND ----------
# ── Cell 7: ICU stay — vista_patient_movement ──────────────────────────────────
# [FIX G] GOLD_PATIENT_MOVEMENT was used in v1.1–v1.4 but has two problems:
#   (1) WARD column = '000000000000' (not populated) — LIKE '%ICU%' never matched
#   (2) Table is stale — data up to ~2015/2016 only, 0 rows for 2025
# Fix: use vista_patient_movement directly with WARD_LOCATION column (varchar(50)
# confirmed, contains real ward names e.g. 'KHCC-4H-ADULT ICU').
# UNION strategy retained: adm_anchor (Strategy 1) + date-range fallback (Strategy 2).

icu_query = f"""
    SELECT DISTINCT
        sa.MRN,
        sa.DISCHARGE_NUMBER,
        1                               AS had_icu_stay,
        vpm.WARD_LOCATION               AS icu_ward_name
    FROM dbo.silver_admissions sa
    JOIN dbo.vista_patient_movement adm_anchor
        ON adm_anchor.NUMBER = sa.ADMISSION_NUMBER
    JOIN dbo.vista_patient_movement vpm
        ON  vpm.MRN = sa.MRN
        AND vpm.ADMISSION_CHECK_IN_MOVEMENT = adm_anchor.DATE_TIME
        AND UPPER(vpm.WARD_LOCATION) LIKE '%ICU%'
    WHERE sa.DISCHARGE_DATE >= '{PRE_START}'
      AND sa.DISCHARGE_DATE  < '{POST_END}'

    UNION

    SELECT DISTINCT
        sa.MRN,
        sa.DISCHARGE_NUMBER,
        1                               AS had_icu_stay,
        vpm.WARD_LOCATION               AS icu_ward_name
    FROM dbo.silver_admissions sa
    JOIN dbo.vista_patient_movement vpm
        ON  vpm.MRN = sa.MRN
        AND vpm.DATE_TIME >= sa.HOSPITALIZATION_DATE
        AND vpm.DATE_TIME <= sa.DISCHARGE_DATE
        AND UPPER(vpm.WARD_LOCATION) LIKE '%ICU%'
    WHERE sa.DISCHARGE_DATE >= '{PRE_START}'
      AND sa.DISCHARGE_DATE  < '{POST_END}'
"""

print("Loading ICU flags...")
df_icu = read_jdbc(icu_query, label="ICU stays (vista_patient_movement)")
df_icu = (
    df_icu
    .groupBy("MRN", "DISCHARGE_NUMBER")
    .agg(
        F.max("had_icu_stay").alias("had_icu_stay"),
        F.first("icu_ward_name").alias("icu_ward_name"),
    )
)

# COMMAND ----------
# ── Cell 8: Surgical flag + attending physician ────────────────────────────────
# [FIX G] Same as Cell 7 — replace GOLD_PATIENT_MOVEMENT with vista_patient_movement
# for surgical detection. Filter on WARD_LOCATION and FACILITY_TREATING_SPECIALTY.
# Attending physician query unchanged — already uses vista_patient_movement correctly.

surgical_query = f"""
    SELECT
        MRN,
        DISCHARGE_NUMBER,
        MAX(is_surgical_case)       AS is_surgical_case
    FROM (
        -- Strategy 1: adm_anchor via ADMISSION_NUMBER DATE_TIME
        SELECT
            sa.MRN,
            sa.DISCHARGE_NUMBER,
            MAX(CASE
                -- [FIX H] Explicit surgical specialty list from Query 1 results.
                -- Removed WARD_LOCATION LIKE '%SURG%' — it matched medical wards
                -- named 'KHCC-3B-MEDICAL/SURGICAL', inflating surgical rate to 56%.
                WHEN vpm.FACILITY_TREATING_SPECIALTY IN (
                    'URO-SURGERY','NEUROSURGERY','GYNECOLOGIC ONCOLOGY SURGERY',
                    'THORACIC','SPINE SURGERY','GI-SURGERY','PLASTIC SURGERY',
                    'PED/SURGERY','ORTHOSURG1','ORTHOSURG2','VASCULAR',
                    'ONCO-PLASTIC SURGERY','Maxillofacial Oncology',
                    'Hepatobiliary&Liver Transp.','hepato-pancreato',
                    'EAR NOSE THROAT'
                )
                OR UPPER(vpm.FACILITY_TREATING_SPECIALTY) LIKE '%SURGICAL ONCOLOGY%'
                OR vpm.WARD_LOCATION = 'KHCC-3C-SURGERY'     THEN 1
                ELSE 0
            END)                    AS is_surgical_case
        FROM dbo.silver_admissions sa
        JOIN dbo.vista_patient_movement adm_anchor
            ON adm_anchor.NUMBER = sa.ADMISSION_NUMBER
        JOIN dbo.vista_patient_movement vpm
            ON  vpm.MRN = sa.MRN
            AND vpm.ADMISSION_CHECK_IN_MOVEMENT = adm_anchor.DATE_TIME
        WHERE sa.DISCHARGE_DATE >= '{PRE_START}'
          AND sa.DISCHARGE_DATE  < '{POST_END}'
        GROUP BY sa.MRN, sa.DISCHARGE_NUMBER

        UNION ALL

        -- Strategy 2: date-range fallback for transfer-originated encounters
        SELECT
            sa.MRN,
            sa.DISCHARGE_NUMBER,
            MAX(CASE
                WHEN vpm.FACILITY_TREATING_SPECIALTY IN (
                    'URO-SURGERY','NEUROSURGERY','GYNECOLOGIC ONCOLOGY SURGERY',
                    'THORACIC','SPINE SURGERY','GI-SURGERY','PLASTIC SURGERY',
                    'PED/SURGERY','ORTHOSURG1','ORTHOSURG2','VASCULAR',
                    'ONCO-PLASTIC SURGERY','Maxillofacial Oncology',
                    'Hepatobiliary&Liver Transp.','hepato-pancreato',
                    'EAR NOSE THROAT'
                )
                OR UPPER(vpm.FACILITY_TREATING_SPECIALTY) LIKE '%SURGICAL ONCOLOGY%'
                OR vpm.WARD_LOCATION = 'KHCC-3C-SURGERY'     THEN 1
                ELSE 0
            END)                    AS is_surgical_case
        FROM dbo.silver_admissions sa
        JOIN dbo.vista_patient_movement vpm
            ON  vpm.MRN = sa.MRN
            AND vpm.DATE_TIME >= sa.HOSPITALIZATION_DATE
            AND vpm.DATE_TIME <= sa.DISCHARGE_DATE
        WHERE sa.DISCHARGE_DATE >= '{PRE_START}'
          AND sa.DISCHARGE_DATE  < '{POST_END}'
        GROUP BY sa.MRN, sa.DISCHARGE_NUMBER
    ) combined
    GROUP BY MRN, DISCHARGE_NUMBER
"""

attending_query = f"""
    SELECT
        MRN,
        DISCHARGE_NUMBER,
        ATTENDING_PHYSICIAN         AS attending_physician
    FROM (
        -- Strategy 1: adm_anchor via ADMISSION_NUMBER DATE_TIME
        SELECT
            sa.MRN,
            sa.DISCHARGE_NUMBER,
            vpm.ATTENDING_PHYSICIAN,
            ROW_NUMBER() OVER (
                PARTITION BY sa.MRN, sa.DISCHARGE_NUMBER
                ORDER BY vpm.DATE_TIME DESC
            )                       AS rn
        FROM dbo.silver_admissions sa
        JOIN dbo.vista_patient_movement adm_anchor
            ON adm_anchor.NUMBER = sa.ADMISSION_NUMBER
        JOIN dbo.vista_patient_movement vpm
            ON  vpm.MRN = sa.MRN
            AND vpm.[TRANSACTION] = 'SPECIALTY TRANSFER'
            AND vpm.ATTENDING_PHYSICIAN IS NOT NULL
            AND vpm.ADMISSION_CHECK_IN_MOVEMENT = adm_anchor.DATE_TIME
        WHERE sa.DISCHARGE_DATE >= '{PRE_START}'
          AND sa.DISCHARGE_DATE  < '{POST_END}'

        UNION ALL

        -- Strategy 2: date-range fallback for transfer-originated encounters
        SELECT
            sa.MRN,
            sa.DISCHARGE_NUMBER,
            vpm.ATTENDING_PHYSICIAN,
            ROW_NUMBER() OVER (
                PARTITION BY sa.MRN, sa.DISCHARGE_NUMBER
                ORDER BY vpm.DATE_TIME DESC
            )                       AS rn
        FROM dbo.silver_admissions sa
        JOIN dbo.vista_patient_movement vpm
            ON  vpm.MRN = sa.MRN
            AND vpm.[TRANSACTION] = 'SPECIALTY TRANSFER'
            AND vpm.ATTENDING_PHYSICIAN IS NOT NULL
            AND vpm.DATE_TIME >= sa.HOSPITALIZATION_DATE
            AND vpm.DATE_TIME <= sa.DISCHARGE_DATE
        WHERE sa.DISCHARGE_DATE >= '{PRE_START}'
          AND sa.DISCHARGE_DATE  < '{POST_END}'
    ) combined
    WHERE rn = 1
"""

print("Loading surgical flags...")
df_surgical = read_jdbc(surgical_query, label="surgical flag (GOLD_PATIENT_MOVEMENT)")

print("Loading attending physicians...")
df_attending = read_jdbc(attending_query, label="attending physician (vista_patient_movement)")

# COMMAND ----------
# ── Cell 9: Discharge summary — vista_notes (direct) ──────────────────────────
# [FIX 3] SILVER_DISCHARGE_SUMMARIES is stale — 0 rows for 2025.
# Confirmed DOCUMENT_TYPE = 'Discharge Summary' in vista_notes (11,427 rows).
# ENTRY_DATE = when the note was entered = completion timestamp.
# Lag = hours between discharge_date and ENTRY_DATE.
# Joined to spine by MRN + nearest discharge summary note to discharge date.
# Deduplication: latest ENTRY_DATE per MRN + discharge date window.

ds_query = f"""
    SELECT
        n.MRN,
        CAST(n.Entry_Date AS DATE)              AS ds_note_date,
        n.Entry_Date                            AS discharge_summary_completed_at,
        n.DOCUMENT_TYPE                         AS ds_document_type,
        n.SIGNED_BY                             AS ds_signed_by,
        n.SERVICE                               AS ds_service,
        -- Completion lag will be calculated in Spark after joining to spine
        ROW_NUMBER() OVER (
            PARTITION BY n.MRN, CAST(n.Entry_Date AS DATE)
            ORDER BY n.Entry_Date DESC
        )                                       AS rn
    FROM dbo.vista_notes n
    WHERE n.DOCUMENT_TYPE = 'Discharge Summary'
      AND n.Entry_Date >= '{PRE_START}'
      AND n.Entry_Date  < '2026-04-01'
"""

print("Loading discharge summaries (vista_notes)...")
df_ds_raw = read_jdbc(ds_query, label="discharge summaries (vista_notes)")
df_ds = df_ds_raw.filter(F.col("rn") == 1).drop("rn")

# COMMAND ----------
# ── Cell 10: Consults — VISTA_CONSULTATIONS_REQUEST ───────────────────────────
# Social work flag: TO_SERVICE LIKE '%SOCIAL%'
# Pending consult proxy: consult requested within 24h before discharge
# [A6] No status/completion column exists in this table.

consults_query = f"""
    SELECT
        MRN,
        COUNT(*)                                    AS total_consults,
        SUM(CASE WHEN UPPER(TO_SERVICE) LIKE '%SOCIAL%'
                 THEN 1 ELSE 0 END)                AS social_work_consults,
        MAX(CASE WHEN UPPER(TO_SERVICE) LIKE '%SOCIAL%'
                 THEN 1 ELSE 0 END)                AS social_work_involved_flag
    FROM dbo.VISTA_CONSULTATIONS_REQUEST
    WHERE DATE_OF_REQUEST >= '{PRE_START}'
      AND DATE_OF_REQUEST  < '{POST_END}'
    GROUP BY MRN
"""

print("Loading consults...")
df_consults = read_jdbc(consults_query, label="consults (VISTA_CONSULTATIONS_REQUEST)")

# COMMAND ----------
# ── Cell 11: Orders — discharge day + meds day before ─────────────────────────
# Radiology / procedures on discharge day: keyword match on ORDERABLE_ITEMS.
# Discharge meds written day before: TO = 'OUTPATIENT MEDICATIONS' [A7].
# Equipment needs: keyword match on ORDERABLE_ITEMS.

orders_day_query = f"""
    SELECT
        MRN,
        CAST(Start_Date AS DATE)            AS order_date,
        MAX(CASE
            WHEN UPPER(ORDERABLE_ITEMS) LIKE '%RADIOL%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%CT %'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%MRI%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%SCAN%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%ULTRASOUND%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%X-RAY%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%XRAY%'    THEN 1 ELSE 0
        END)                                AS radiology_on_discharge_day,
        MAX(CASE
            WHEN UPPER(ORDERABLE_ITEMS) LIKE '%PROCEDURE%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%BIOPSY%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%SCOPE%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%SURGERY%' THEN 1 ELSE 0
        END)                                AS procedure_on_discharge_day,
        MAX(CASE
            WHEN UPPER(ORDERABLE_ITEMS) LIKE '%EQUIPMENT%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%WHEELCHAIR%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%OXYGEN%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%WALKER%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%BED%'
              OR UPPER(ORDERABLE_ITEMS) LIKE '%PUMP%'    THEN 1 ELSE 0
        END)                                AS equipment_needed_flag
    FROM dbo.vista_orders
    WHERE Start_Date >= '{PRE_START}'
      AND Start_Date  < '{POST_END}'
    GROUP BY MRN, CAST(Start_Date AS DATE)
"""

meds_day_before_query = f"""
    SELECT
        MRN,
        CAST(WHEN_ENTERED AS DATE)          AS meds_written_date,
        MAX(CASE
            WHEN UPPER([TO]) LIKE '%OUTPATIENT MED%'
              OR UPPER(PATIENT_CLASS) = 'OUTPATIENT' THEN 1 ELSE 0
        END)                                AS discharge_meds_written_flag
    FROM dbo.vista_orders
    WHERE WHEN_ENTERED >= '{PRE_START}'
      AND WHEN_ENTERED  < '{POST_END}'
    GROUP BY MRN, CAST(WHEN_ENTERED AS DATE)
"""

print("Loading orders (discharge day)...")
df_orders_day = read_jdbc(orders_day_query, label="orders on discharge day")

print("Loading orders (meds day before)...")
df_meds_before = read_jdbc(meds_day_before_query, label="meds written day before")

# COMMAND ----------
# ── Cell 12: Readmissions — computed from silver_admissions ───────────────────
# [FIX I] silver_readmissions is stale — 0 rows for Jul-Dec 2025.
# Readmissions now computed directly via silver_admissions self-join:
#   7-day  : same MRN has a new HOSPITALIZATION_DATE within 7 days of DISCHARGE_DATE
#   30-day : same MRN has a new HOSPITALIZATION_DATE within 30 days of DISCHARGE_DATE
# Excludes cancelled admissions. The next admission's diagnosis is captured.
# Linked by DISCHARGE_NUMBER (unique encounter key) — no timestamp tolerance needed.

readmissions_query = f"""
    SELECT
        MRN,
        DISCHARGE_NUMBER,
        discharge_date_base,
        readmission_datetime,
        hours_to_readmission,
        CASE WHEN hours_to_readmission <= 168  THEN 1 ELSE 0 END AS readmitted_7d_flag,
        CASE WHEN hours_to_readmission <= 720  THEN 1 ELSE 0 END AS readmitted_30d_flag,
        primary_diagnosis_at_readmission
    FROM (
        SELECT
            base.MRN,
            base.DISCHARGE_NUMBER,
            base.DISCHARGE_DATE                             AS discharge_date_base,
            MIN(next_adm.HOSPITALIZATION_DATE)              AS readmission_datetime,
            DATEDIFF(HOUR,
                base.DISCHARGE_DATE,
                MIN(next_adm.HOSPITALIZATION_DATE))         AS hours_to_readmission,
            MIN(next_adm.DIAGNOSIS_SHORT)                   AS primary_diagnosis_at_readmission
        FROM dbo.silver_admissions base
        JOIN dbo.silver_admissions next_adm
            ON  next_adm.MRN = base.MRN
            AND next_adm.HOSPITALIZATION_DATE > base.DISCHARGE_DATE
            AND next_adm.HOSPITALIZATION_DATE <= DATEADD(DAY, 30, base.DISCHARGE_DATE)
            AND UPPER(ISNULL(next_adm.DISCHARGE_TYPE,'')) NOT IN (
                'CANCELLED ADMISSION','CANCELLED PROCEDURE'
            )
        WHERE base.DISCHARGE_DATE >= '{PRE_START}'
          AND base.DISCHARGE_DATE  < '{POST_END}'
          AND UPPER(ISNULL(base.DISCHARGE_TYPE,'')) NOT IN (
                'CANCELLED ADMISSION','CANCELLED PROCEDURE'
          )
        GROUP BY base.MRN, base.DISCHARGE_NUMBER, base.DISCHARGE_DATE
    ) inner_q
"""

print("Loading readmissions (computed from silver_admissions)...")
df_readmissions = read_jdbc(readmissions_query, label="readmissions (self-join)")

# COMMAND ----------
# ── Cell 13: ED revisits — vista_patient_movement EMERGENCY rows ───────────────
# [FIX I] silver_er_revisits is stale — 0 rows for Jul-Dec 2025.
# ED revisit within 72h = same MRN has an EMERGENCY admission in
# vista_patient_movement within 72 hours of DISCHARGE_DATE.
# Uses TRANSACTION='ADMISSION' and TYPE_OF_MOVEMENT='EMERGENCY' to identify ER visits.

er_query = f"""
    SELECT
        MRN,
        DISCHARGE_NUMBER,
        er_first_visit_time,
        hours_to_revisit,
        CASE WHEN hours_to_revisit <= 72 THEN 1 ELSE 0 END AS ed_revisit_72h_flag,
        revisit_diagnosis
    FROM (
        SELECT
            base.MRN,
            base.DISCHARGE_NUMBER,
            MIN(er.DATE_TIME)                               AS er_first_visit_time,
            DATEDIFF(HOUR,
                base.DISCHARGE_DATE,
                MIN(er.DATE_TIME))                          AS hours_to_revisit,
            MIN(er.DIAGNOSIS_SHORT)                         AS revisit_diagnosis
        FROM dbo.silver_admissions base
        JOIN dbo.vista_patient_movement er
            ON  er.MRN = base.MRN
            AND er.[TRANSACTION] = 'ADMISSION'
            AND er.TYPE_OF_MOVEMENT = 'EMERGENCY'
            AND er.DATE_TIME > base.DISCHARGE_DATE
            AND er.DATE_TIME <= DATEADD(HOUR, 72, base.DISCHARGE_DATE)
        WHERE base.DISCHARGE_DATE >= '{PRE_START}'
          AND base.DISCHARGE_DATE  < '{POST_END}'
          AND UPPER(ISNULL(base.DISCHARGE_TYPE,'')) NOT IN (
                'CANCELLED ADMISSION','CANCELLED PROCEDURE'
          )
        GROUP BY base.MRN, base.DISCHARGE_NUMBER, base.DISCHARGE_DATE
    ) inner_q
"""

print("Loading ED revisits (computed from vista_patient_movement)...")
df_er = read_jdbc(er_query, label="ED revisits (vista_patient_movement)")

# COMMAND ----------
# ── Cell 14: Follow-up appointments — vista_appointment ───────────────────────
# Booked before discharge : DATE_APPT_MADE < discharge_datetime
# Attended               : CHECKIN not null AND NOSHOW <> 'YES'
# [A9] Window: first appointment within 90 days post-discharge.
# Cancelled appointments (CANCEL_DATETIME not null) are excluded.

appt_query = f"""
    SELECT
        MRN,
        Appointment_Date,
        DATE_APPT_MADE,
        CHECKIN,
        NOSHOW,
        CANCEL_DATETIME,
        RESOURCE                            AS appointment_resource,
        CASE WHEN CHECKIN IS NOT NULL
              AND UPPER(ISNULL(NOSHOW,'')) <> 'YES' THEN 1
             ELSE 0
        END                                 AS followup_attended_flag,
        ROW_NUMBER() OVER (
            PARTITION BY MRN
            ORDER BY Appointment_Date ASC
        )                                   AS appt_rn
    FROM dbo.vista_appointment
    WHERE Appointment_Date >= '{PRE_START}'
      AND Appointment_Date  < '2026-04-01'
      AND CANCEL_DATETIME IS NULL
"""

print("Loading follow-up appointments...")
df_appt_raw = read_jdbc(appt_query, label="appointments (vista_appointment)")
df_appt = df_appt_raw.filter(F.col("appt_rn") == 1).drop("appt_rn")

# COMMAND ----------
# ── Cell 15: Assemble — join all components to spine ──────────────────────────
# Strategy: Spark joins on MRN + date/time keys.
# All joins are LEFT so that encounters are never dropped due to missing data.

print("Assembling final dataset...")

# --- 0. [FIX A] Decode VISTA MRN → raw MRN ---
# VISTA MRN = optimus.encode(raw_mrn), so raw_mrn = optimus.encode(vista_mrn)
# Kept as separate column; encoded MRN retained for SQL joins
df = df_spine.withColumn("raw_mrn", decode_mrn_udf(F.col("MRN")))

# --- 1. Demographics: join on MRN ---
df = df.join(df_demo, on="MRN", how="left")

# --- 2. Age at admission (calculated in Spark) ---
df = df.withColumn(
    "age_at_admission",
    (F.datediff(F.col("admission_datetime"), F.col("DOB")) / 365.25).cast("int")
).drop("DOB")

# --- [FIX B2] Remap INTERWARD TRANSFER values to readable labels ---
# Transfer-originated encounters have TYPE_OF_MOVEMENT = 'INTERWARD TRANSFER'
# for both admission_type and discharge_destination — remap to clinical labels
df = df.withColumn(
    "admission_type_grouped",
    F.when(F.col("admission_type_grouped") == "INTERWARD TRANSFER", "Transfer (Ward)")
     .otherwise(F.col("admission_type_grouped"))
)
df = df.withColumn(
    "discharge_destination",
    F.when(F.col("discharge_destination") == "INTERWARD TRANSFER", "Internal Transfer")
     .otherwise(F.col("discharge_destination"))
)

# --- 3. 30-day post-discharge mortality ---
df = df.withColumn(
    "death_within_30d_post_discharge_flag",
    F.when(
        (F.col("date_of_death").isNotNull()) &
        (F.datediff(F.col("date_of_death"), F.col("discharge_datetime")).between(0, 30)) &
        (F.col("inpatient_death_flag") == 0),
        1
    ).otherwise(0)
)

# --- 4. Attending physician: join on MRN + DISCHARGE_NUMBER [FIX 4] ---
df = df.join(df_attending, on=["MRN", "DISCHARGE_NUMBER"], how="left")

# --- 5. Surgical flag: join on MRN + DISCHARGE_NUMBER [FIX 2] ---
df = df.join(df_surgical, on=["MRN", "DISCHARGE_NUMBER"], how="left") \
       .fillna({"is_surgical_case": 0})

# --- 6. ICU flag: join on MRN + DISCHARGE_NUMBER [FIX 2] ---
df = df.join(df_icu, on=["MRN", "DISCHARGE_NUMBER"], how="left") \
       .fillna({"had_icu_stay": 0})

# --- 7. Discharge summary: join on MRN + note date within ±3 days of discharge [FIX 3]
# Summary may be written 0-3 days after discharge — use a date window join
df_ds_j = df_ds.withColumnRenamed("MRN", "ds_MRN")
df = df.join(
    df_ds_j,
    (df["MRN"] == df_ds_j["ds_MRN"]) &
    (df_ds_j["ds_note_date"] >= df["discharge_date"]) &
    (df_ds_j["ds_note_date"] <= F.date_add(F.col("discharge_date"), 3)),
    how="left"
).drop("ds_MRN")

# Discharge summary completion lag: hours from discharge_datetime to note entry
df = df.withColumn(
    "discharge_summary_lag_hours",
    F.when(
        F.col("discharge_summary_completed_at").isNotNull(),
        (F.unix_timestamp("discharge_summary_completed_at") -
         F.unix_timestamp("discharge_datetime")) / 3600.0
    ).otherwise(F.lit(None).cast(DoubleType()))
)

# [FIX F] Deduplicate discharge summary fanout — ±3 day window can match
# multiple notes per encounter. Keep earliest (first summary written).
ds_window = Window.partitionBy("DISCHARGE_NUMBER").orderBy(
    F.col("discharge_summary_completed_at").asc_nulls_last()
)
df = df.withColumn("_ds_rn", F.row_number().over(ds_window)) \
       .filter(F.col("_ds_rn") == 1) \
       .drop("_ds_rn")

# --- 8. Consults: join on MRN ---
df = df.join(df_consults, on="MRN", how="left").fillna({
    "total_consults": 0,
    "social_work_consults": 0,
    "social_work_involved_flag": 0,
})

# --- 9. Orders on discharge day: join on MRN + discharge_date ---
df_orders_day_r = df_orders_day.withColumnRenamed("order_date", "discharge_date_ord") \
                               .withColumnRenamed("MRN", "ord_MRN")
df = df.join(
    df_orders_day_r,
    (df["MRN"] == df_orders_day_r["ord_MRN"]) &
    (df["discharge_date"] == df_orders_day_r["discharge_date_ord"]),
    how="left"
).drop("ord_MRN", "discharge_date_ord").fillna({
    "radiology_on_discharge_day": 0,
    "procedure_on_discharge_day": 0,
    "equipment_needed_flag": 0,
})

# --- 10. Meds day before: join on MRN + day before discharge ---
df = df.withColumn("day_before_discharge", F.date_sub(F.col("discharge_date"), 1))
df_meds_r = df_meds_before.withColumnRenamed("meds_written_date", "meds_date_key") \
                          .withColumnRenamed("MRN", "meds_MRN")
df = df.join(
    df_meds_r,
    (df["MRN"] == df_meds_r["meds_MRN"]) &
    (df["day_before_discharge"] == df_meds_r["meds_date_key"]),
    how="left"
).drop("meds_MRN", "meds_date_key", "day_before_discharge") \
 .fillna({"discharge_meds_written_flag": 0})

# --- 11. Readmissions: join on MRN + DISCHARGE_NUMBER [FIX I] ---
# Now computed from silver_admissions self-join — direct key match on DISCHARGE_NUMBER
df_ra = df_readmissions.withColumnRenamed("MRN", "ra_MRN") \
                       .withColumnRenamed("DISCHARGE_NUMBER", "ra_DISCHARGE_NUMBER") \
                       .withColumnRenamed("discharge_date_base", "ra_discharge_date")
df = df.join(
    df_ra,
    (df["MRN"] == df_ra["ra_MRN"]) &
    (df["DISCHARGE_NUMBER"] == df_ra["ra_DISCHARGE_NUMBER"]),
    how="left"
).drop("ra_MRN", "ra_DISCHARGE_NUMBER", "ra_discharge_date") \
 .fillna({"readmitted_7d_flag": 0, "readmitted_30d_flag": 0})

# --- 12. ED revisits: join on MRN + DISCHARGE_NUMBER [FIX I] ---
# Now computed from vista_patient_movement EMERGENCY rows — direct key match
df_er_j = df_er.withColumnRenamed("MRN", "er_MRN") \
               .withColumnRenamed("DISCHARGE_NUMBER", "er_DISCHARGE_NUMBER")
df = df.join(
    df_er_j,
    (df["MRN"] == df_er_j["er_MRN"]) &
    (df["DISCHARGE_NUMBER"] == df_er_j["er_DISCHARGE_NUMBER"]),
    how="left"
).drop("er_MRN", "er_DISCHARGE_NUMBER").fillna({"ed_revisit_72h_flag": 0})

# --- 13. Follow-up appointments: first appt within 90 days of discharge ---
df_appt_r = df_appt.withColumnRenamed("Appointment_Date", "appt_date_key") \
                   .withColumnRenamed("MRN", "appt_MRN")
df = df.join(
    df_appt_r,
    (df["MRN"] == df_appt_r["appt_MRN"]) &
    (df_appt_r["appt_date_key"] >= df["discharge_date"]) &
    (df_appt_r["appt_date_key"] <= F.expr("date_add(discharge_date, 90)")),
    how="left"
).drop("appt_MRN")

# --- 14. Follow-up booked before discharge flag ---
df = df.withColumn(
    "followup_booked_before_discharge_flag",
    F.when(F.col("DATE_APPT_MADE") < F.col("discharge_datetime"), 1).otherwise(0)
)

# --- 15. Discharge order time — not available in VISTA orders [A1] ---
df = df.withColumn("discharge_order_datetime", F.lit(None).cast(TimestampType()))
df = df.withColumn("discharge_order_to_out_hours", F.lit(None).cast(DoubleType()))

# --- 16. LLM Phase 2 placeholder columns ---
for col_name in [
    "functional_status_at_discharge",
    "expected_discharge_date_documented_early",
    "reason_for_admission",
    "comorbidities",
    "in_hospital_complications",
]:
    df = df.withColumn(col_name, F.lit(None).cast(StringType()))

# --- 17. Metadata ---
df = df.withColumn("extraction_datetime", F.current_timestamp())
df = df.withColumn("extractor_version", F.lit("v1.6"))

print(f"✅ Assembly complete — {df.count():,} rows")

