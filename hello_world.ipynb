    html_body = f"""
    <html>
    <body style="background-color:#F8F9FA;font-family:Arial,sans-serif;margin:0;padding:0;">
    <div style="max-width:700px;margin:30px auto;background-color:#FFFFFF;border-radius:8px;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,0.1);">

      <!-- Header -->
      <div style="background-color:#003B6F;padding:24px 28px;">
        <p style="color:#B3D4E8;margin:0;font-size:13px;">King Hussein Cancer Center — AIDI Team</p>
        <h2 style="color:#FFFFFF;margin:6px 0 0;font-size:20px;">Discharge Planning Study — Phase 1 Extract</h2>
      </div>

      <!-- Badge + timestamp -->
      <div style="background-color:#0077A8;padding:10px 28px;display:flex;align-items:center;gap:12px;">
        {mode_badge}
        <span style="color:#FFFFFF;font-size:12px;">Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')} | Extractor v1.6</span>
      </div>

      <!-- Body -->
      <div style="padding:24px 28px;">
        <p style="color:#2C3E50;font-size:14px;margin-top:0;">
          The Phase 1 structured extraction has completed. The CSV is attached.
          LLM variables (functional status, comorbidities, etc.) will be populated in Phase 2.
        </p>

        {stats_html}

        <div style="background-color:#FFF3CD;border-left:4px solid #FFC107;padding:12px 16px;margin-top:20px;border-radius:4px;">
          <p style="margin:0;font-size:13px;color:#856404;">
            <strong>⚠️ Assumptions to review:</strong>
            Discharge order time is unavailable (NULL) — discharge_datetime used as proxy.
            Surgical flag is keyword-based — manual review recommended.
            Pending consults is a proxy (no status column in VISTA).
          </p>
        </div>

        <p style="color:#6C757D;font-size:12px;margin-top:20px;">
          Output table: <code>{OUTPUT_TABLE}</code><br>
          CSV: <code>{OUTPUT_CSV_PATH}</code>
        </p>
      </div>

      <!-- Footer -->
      <div style="background-color:#F2F3F4;padding:14px 28px;border-top:1px solid #DEE2E6;">
        <p style="color:#6C757D;font-size:11px;margin:0;">
          Confidential — KHCC Internal Use Only | BCC: {BCC_EMAIL}
        </p>
      </div>

    </div>
    </body>
    </html>
    """

    # Build message
    msg = MIMEMultipart()
    msg["Subject"] = f"{'[TEST] ' if TEST_MODE else ''}Discharge Planning Phase 1 Extract — {datetime.now().strftime('%Y-%m-%d')}"
    msg["From"]    = username
    msg["To"]      = ", ".join(recipients)
    msg["Bcc"]     = BCC_EMAIL
    msg.attach(MIMEText(html_body, "html"))

    # Attach CSV
    csv_local_path = OUTPUT_CSV_PATH.replace("/dbfs", "")
    if os.path.exists(csv_local_path):
        with open(csv_local_path, "rb") as f:
            part = MIMEBase("application", "octet-stream")
            part.set_payload(f.read())
            encoders.encode_base64(part)
            part.add_header(
                "Content-Disposition",
                f"attachment; filename=discharge_planning_phase1_{datetime.now().strftime('%Y%m%d')}.csv"
            )
            msg.attach(part)
    else:
        print("⚠️  CSV file not found — sending email without attachment")

    # Send
    try:
        with smtplib.SMTP("smtp.gmail.com", 587) as server:
            server.starttls()
            server.login(username, password)
            server.send_message(msg)
        print(f"✅ Email sent to: {recipients}")
    except Exception as e:
        logger.error(f"Email failed: {e}")
        print(f"❌ Email failed: {e}")

