# discharge_order_datetime           — NULL [A1]: not available in vista_orders
# discharge_order_to_out_hours       — NULL [A1]: depends on discharge_order_datetime
# discharge_summary_completed_at     — ENTRY_DATE of discharge summary note
# discharge_summary_lag_hours        — Hours from discharge to summary completion
# admission_diagnosis                — From SILVER_DISCHARGE_SUMMARIES
# discharge_diagnosis                — From SILVER_DISCHARGE_SUMMARIES
# patient_condition_at_discharge     — From SILVER_DISCHARGE_SUMMARIES
# pending_test_results               — From SILVER_DISCHARGE_SUMMARIES
# follow_up_instructions             — From SILVER_DISCHARGE_SUMMARIES
# code_status                        — From SILVER_DISCHARGE_SUMMARIES
# total_consults                     — Count of consults during study window for this MRN
